OPENAI_API_KEY=sk-your-openai-api-key-here
# Coach / recommend (heavy)
OPENAI_MODEL=gpt-5.6
# Meal scan vision — quality-focused but faster than gpt-5.6
OPENAI_VISION_MODEL=gpt-4.1
OPENAI_VISION_REASONING=low
# User meal corrections (prior + note) — fastest path
OPENAI_VISION_CORRECT_MODEL=gpt-4.1-mini
# Coach + “지금 뭐먹지” — fast default
OPENAI_FAST_MODEL=gpt-4.1-mini
OPENAI_FAST_REASONING=minimal
